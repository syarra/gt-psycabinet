				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "## Event sourcing and persistence\n\nAll actions (adding patients, recording sessions, generating receipts) are recorded as events. Events are persisted to a STON log file and can be replayed to rebuild state from scratch:"
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-01T00:02:59.727098+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-01T00:02:59.727098+02:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "x6rJz68RT1WzQV6gZWoWMg=="
				},
				"code" : "\"Set a log file to enable persistence\"\ncabinet := CbCabinetManager new.\ncabinet eventLogFile: '/path/to/cabinet-events.ston'.\n\n\"Later, rebuild state from the log\"\ncabinet2 := CbCabinetManager new.\ncabinet2 eventLogFile: '/path/to/cabinet-events.ston'.\ncabinet2 replayFromFile."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
