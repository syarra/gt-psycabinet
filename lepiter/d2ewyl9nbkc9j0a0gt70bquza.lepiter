				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "# How to use CbCabinetManager\n\n`CbCabinetManager` is the central object for managing a psychology practice. It tracks patients, sessions, receipts, and finances through an event-sourced architecture — every action is recorded as an event and persisted to a log file, so the full history can be replayed at any time."
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-01T00:01:59.286642+02:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
