				"code" : "cabinet := CbCabinetManagerExamples new exampleCabinetWithPatients.\npatient := cabinet patients first.\n\n\"Generate a receipt covering all uncovered sessions\"\nreceipt := patient generateReceiptForUncoveredSessions: Date today.\nreceipt."
